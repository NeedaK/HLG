    <!-- Overview of Admissions Process -->
    <section class="admissions-overview">
        <h2>Overview of the Admission Process</h2>
        <p>Applying to HLGU is a simple and straightforward process. Follow these steps:</p>
        <ul>
            <li>Complete the online application.</li>
            <li>Submit required documents (transcripts, test scores, etc.).</li>
            <li>Schedule an admissions interview (if required).</li>
            <li>Receive your acceptance letter and enrollment details.</li>
        </ul>
    </section>

    <!-- Admission Requirements -->
    <section class="requirements">
        <h2>Admission Requirements</h2>

        <div class="requirements-container">
            <div class="requirement-box">
                <h3>Undergraduate Programs</h3>
                <ul>
                    <li>Completed online application</li>
                    <li>High school transcript or GED</li>
                    <li>ACT/SAT scores (optional but recommended)</li>
                    <li>Personal statement (if applicable)</li>
                </ul>
            </div>

            <div class="requirement-box">
                <h3>Graduate Programs</h3>
                <ul>
                    <li>Bachelor’s degree from an accredited institution</li>
                    <li>Completed online graduate application</li>
                    <li>Official college transcripts</li>
                    <li>Letters of recommendation</li>
                    <li>Personal statement and/or resume</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Online Application Link -->
    <section class="apply-now">
        <h2>Ready to Apply?</h2>
        <p>Take the next step and start your journey with HLGU.</p>
